{
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },

  "AllowedHosts": "*",

  "KeyVault": {
    "VaultUri": ""
  },

  "McpKql": {
    "ServerCommand": "dotnet run --project src/Hosts/OpsCopilot.McpHost/OpsCopilot.McpHost.csproj",
    "TimeoutSeconds": 90
  },

  "Governance": {
    "Defaults": {
      "AllowedTools": [ "kql_query", "runbook_search" ],
      "TriageEnabled": true,
      "TokenBudget": null
    },
    "TenantOverrides": {}
  },

  "Packs": {
    "RootPath": "packs",
    "DeploymentMode": "A",
    "EvidenceExecutionEnabled": false,
    "EvidenceMaxRows": 50,
    "EvidenceMaxChars": 4000,
    "AzureMonitorQueryTimeoutMs": 5000,
    "SafeActionsEnabled": false
  },

  "Reporting": {
    "ServiceBus": {
      "FullyQualifiedNamespace": "",
      "TenantId": ""
    },
    "AzureChange": {
      "SubscriptionId": "",
      "TenantId": ""
    }
  },

  "AgentRun": {
    "Idempotency": {
      "WindowMinutes": 60
    },
    "StuckRunWatchdog": {
      "IntervalSeconds": 300,
      "ThresholdMinutes": 30
    }
  },

  "AI": {
    "Provider": "",
    "AzureOpenAI": {
      "Endpoint": "",
      "DeploymentName": "gpt-4o-mini",
      "EmbeddingDeploymentName": "text-embedding-3-small"
    }
  },

  "Rag": {
    "UseVectorRunbooks": false,
    "UseVectorMemory": false,
    "VectorBackend": "InMemory",
    "AzureAISearch": {
      "Endpoint": "",
      "RunbooksIndexName": "opscopilot-runbooks",
      "MemoryIndexName": "opscopilot-incident-memory"
    },
    "Qdrant": {
      "Host": "",
      "Port": 6334,
      "ApiKey": "",
      "RunbooksCollectionName": "opscopilot-runbooks",
      "MemoryCollectionName": "opscopilot-incident-memory"
    }
  },

  "Authentication": {
    "Entra": {
      "TenantId": "",
      "Audience": "",
      "ClientId": "dfdb8f36-cf0b-41d0-bcd6-92a063dba954",
      "ClientSecret": ""
    },
    "Cookie": {
      "Name": "OcSession",
      "ExpireMinutes": 480
    },
    "DevBypass": false
  },

  "RateLimiting": {
    "Triage": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Default": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    }
  },

  "Telemetry": {
    "OtlpEndpoint": ""
  },

  "Tenancy": {
    "Features": {
      "LiveConnectorHealthValidation": false
    }
  }


}
