{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "OpsCopilot": "Debug"
    }
  },

  "McpKql": {
    "ServerCommand": "dotnet run --project src/Hosts/OpsCopilot.McpHost/OpsCopilot.McpHost.csproj --no-build",
    "TimeoutSeconds": 120,
    "ServerUrl": ""
  },

  "McpArm": {
    "TimeoutSeconds": 30
  },

  "Governance": {
    "Defaults": {
      "AllowedTools": [ "kql_query", "runbook_search" ],
      "TriageEnabled": true,
      "TokenBudget": null
    },
    "TenantOverrides": {}
  },

  "SafeActions": {
    "EnableExecution": false,
    "EnableRealHttpProbe": false,
    "EnableAzureReadExecutions": false,
    "HttpProbeTimeoutMs": 5000,
    "HttpProbeMaxResponseBytes": 1024,
    "AzureReadTimeoutMs": 5000,
    "EnableAzureMonitorReadExecutions": false,
    "AzureMonitorQueryTimeoutMs": 5000,
    "AllowedAzureSubscriptionIds": [],
    "AllowedLogAnalyticsWorkspaceIds": [ "08e80da0-bf2b-4bde-9e9d-08e67c12cab6", "6b530cc6-14bb-4fad-9577-3a349209ae1c" ],
    "AllowedExecutionTenants": {},
    "AllowActorHeaderFallback": true,
    "AllowAnonymousActorFallback": true,
    "EnableExecutionThrottling": false,
    "ExecutionThrottleWindowSeconds": 60,
    "ExecutionThrottleMaxAttemptsPerWindow": 5,
    "ActionTypes": [
      { "ActionType": "restart_pod",          "RiskTier": "High",   "Enabled": true },
      { "ActionType": "http_probe",           "RiskTier": "Low",    "Enabled": true },
      { "ActionType": "dry_run",              "RiskTier": "Low",    "Enabled": true },
      { "ActionType": "azure_resource_get",   "RiskTier": "Medium", "Enabled": true },
      { "ActionType": "azure_monitor_query",  "RiskTier": "Medium", "Enabled": true }
    ]
  },

  "AgentRuns": {
    "SessionStore": {
      "Provider": "InMemory"
      // For Redis, set:
      // "Provider": "Redis",
      // "ConnectionString": "localhost:6379"
    }
  },

  "Packs": {
    "RootPath": "packs",
    "DeploymentMode": "B",
    "EvidenceExecutionEnabled": true,
    "EvidenceMaxRows": 50,
    "EvidenceMaxChars": 4000,
    "AzureMonitorQueryTimeoutMs": 5000,
    "SafeActionsEnabled": true
  },

  "Observability": {
    "LogAnalyticsWorkspaceId": "08e80da0-bf2b-4bde-9e9d-08e67c12cab6"
  },

  "Reporting": {
    "ServiceBus": {
      "FullyQualifiedNamespace": "",
      "TenantId": ""
    }
  },

  "AI": {
    "Provider": "GitHubModels",
    "GitHubModels": {
      "Endpoint": "https://models.inference.ai.azure.com",
      "ModelId": "gpt-4o-mini"
    }
  },

  // Per-tenant workspace routing.
  // Key = tenant GUID passed in the request ActorContext.
  // Each tenant resolves its own Log Analytics workspace (and optionally App Insights resource).
  // AllowedLogAnalyticsWorkspaceIds in SafeActions acts as the security allowlist —
  // any workspace resolved here must also appear there.
  "Tenants": {
    "4a72b866-99a4-4388-b881-cef9c8480b1c": {
      "Observability": {
        "LogAnalyticsWorkspaceId": "08e80da0-bf2b-4bde-9e9d-08e67c12cab6"
        // "AppInsightsResourcePath": "/subscriptions/{sub}/resourceGroups/{rg}/providers/microsoft.insights/components/{name}"
      }
    }
  }
}
