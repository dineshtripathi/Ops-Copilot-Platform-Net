{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information",
      "OpsCopilot": "Debug"
    }
  },

  // REQUIRED: SQL connection string for Packs infrastructure (migrations + pack state).
  // Set ConnectionStrings:Sql here or via SQL_CONNECTION_STRING env var.
  // Example (SQL Server Express LocalDB): "Server=(localdb)\\mssqllocaldb;Database=OpsCopilot;Trusted_Connection=True;TrustServerCertificate=True"
  // Example (Docker SQL Server):          "Server=localhost,1433;Database=OpsCopilot;User Id=sa;Password=<your-pw>;TrustServerCertificate=True"
  "ConnectionStrings": {
    "Sql": ""
  },

  "McpKql": {
    "ServerCommand": "dotnet run --project src/Hosts/OpsCopilot.McpHost/OpsCopilot.McpHost.csproj --no-build",
    "TimeoutSeconds": 120,
    "ServerUrl": ""
  },

  "McpArm": {
    "TimeoutSeconds": 30
  },

  "Packs": {
    "RootPath": "packs",
    "DeploymentMode": "B",
    "EvidenceExecutionEnabled": true,
    "EvidenceMaxRows": 50,
    "EvidenceMaxChars": 4000,
    "AzureMonitorQueryTimeoutMs": 5000,
    "SafeActionsEnabled": true
  },

  "SafeActions": {
    "EnableExecution": false,
    "EnableRealHttpProbe": false,
    "EnableAzureReadExecutions": false,
    "AzureReadTimeoutMs": 5000,
    "EnableAzureMonitorReadExecutions": false,
    "AzureMonitorQueryTimeoutMs": 5000,
    "AllowedAzureSubscriptionIds": [],
    "AllowedLogAnalyticsWorkspaceIds": [ "08e80da0-bf2b-4bde-9e9d-08e67c12cab6", "6b530cc6-14bb-4fad-9577-3a349209ae1c" ],
    "AllowedExecutionTenants": {},
    "AllowActorHeaderFallback": true,
    "AllowAnonymousActorFallback": true,
    "EnableExecutionThrottling": false,
    "ExecutionThrottleWindowSeconds": 60,
    "ExecutionThrottleMaxAttemptsPerWindow": 5,
    "ActionTypes": [
      { "ActionType": "azure_monitor_query", "RiskTier": "Medium", "Enabled": true },
      { "ActionType": "dry_run",             "RiskTier": "Low",    "Enabled": true }
    ]
  },

  "Observability": {
    // Global fallback — used when no per-tenant entry matches.
    "LogAnalyticsWorkspaceId": "08e80da0-bf2b-4bde-9e9d-08e67c12cab6"
  },

  // Per-tenant workspace routing.
  // Key = tenant GUID from ActorContext. Resolves workspace before falling back to Observability global.
  "Tenants": {
    "4a72b866-99a4-4388-b881-cef9c8480b1c": {
      "Observability": {
        "LogAnalyticsWorkspaceId": "08e80da0-bf2b-4bde-9e9d-08e67c12cab6"
        // "AppInsightsResourcePath": "/subscriptions/{sub}/resourceGroups/{rg}/providers/microsoft.insights/components/{name}"
      }
    }
  },

  "AlertIngestion": {
    "Worker": {
      "PollIntervalSeconds": 30
    }
  },

  "Digest": {
    "Worker": {
      "IntervalHours": 1
    }
  },

  "Reporting": {
    "ServiceBus": {
      // Dead-letter replay worker: set FullyQualifiedNamespace to your Service Bus namespace,
      // e.g. "opscopilot-dev.servicebus.windows.net"
      "FullyQualifiedNamespace": "",
      "TenantId": "4a72b866-99a4-4388-b881-cef9c8480b1c"
    }
  }
}
