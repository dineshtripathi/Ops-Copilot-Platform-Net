@inherits LayoutComponentBase
@inject Microsoft.AspNetCore.Components.NavigationManager Nav

@{
    var _q = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
    var _tid = _q.TryGetValue("tenantId", out var _tids) ? (_tids.FirstOrDefault() ?? "") : "";
    var _ts = string.IsNullOrEmpty(_tid) ? "" : $"?tenantId={Uri.EscapeDataString(_tid)}";
    var _path = new Uri(Nav.Uri).AbsolutePath;
    var _segments = _path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
    var _contextLabel = _segments.Length >= 3 && _segments[0] == "app" && _segments[1] == "runs"
        ? $"Run {_segments[2][..Math.Min(8, _segments[2].Length)]}"
        : (_segments.Length >= 3 && _segments[0] == "app" && _segments[1] == "sessions"
            ? $"Session {_segments[2][..Math.Min(8, _segments[2].Length)]}"
            : "No active incident");
}

<div class="oc-shell">
    <div class="oc-layout-with-sidebar">
        <nav class="oc-sidebar" aria-label="Primary navigation">
            <div class="oc-sidebar-brand">
                <span class="oc-brand-mark" aria-hidden="true">🚀</span>
                <div class="oc-sidebar-brand-copy">
                    <span class="oc-brand">OpsCopilot</span>
                    <span class="oc-brand-subtitle">Operator Command Center</span>
                </div>
            </div>
            <div class="oc-sidebar-section-label">Navigate</div>
            <ul class="oc-nav-list" role="list">
                <li>
                    <a class="oc-nav-link @(_path.StartsWith("/app/dashboard") ? "oc-nav-link--active" : "")"
                       href="/app/dashboard@_ts">
                        <span class="oc-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M4.25 2A2.25 2.25 0 0 0 2 4.25v2.5A2.25 2.25 0 0 0 4.25 9h2.5A2.25 2.25 0 0 0 9 6.75v-2.5A2.25 2.25 0 0 0 6.75 2h-2.5Zm8 0A2.25 2.25 0 0 0 10 4.25v2.5A2.25 2.25 0 0 0 12.25 9h2.5A2.25 2.25 0 0 0 17 6.75v-2.5A2.25 2.25 0 0 0 14.75 2h-2.5Zm-8 8A2.25 2.25 0 0 0 2 12.25v2.5A2.25 2.25 0 0 0 4.25 17h2.5A2.25 2.25 0 0 0 9 14.75v-2.5A2.25 2.25 0 0 0 6.75 10h-2.5Zm8 0A2.25 2.25 0 0 0 10 12.25v2.5A2.25 2.25 0 0 0 12.25 17h2.5A2.25 2.25 0 0 0 17 14.75v-2.5A2.25 2.25 0 0 0 14.75 10h-2.5Z" clip-rule="evenodd"/></svg>
                        </span>
                        Dashboard
                    </a>
                </li>
                <li>
                    <a class="oc-nav-link @(_path.StartsWith("/app/runs") || _path.StartsWith("/app/sessions") ? "oc-nav-link--active" : "")"
                       href="/app/dashboard@_ts">
                        <span class="oc-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.17-.17 2.63-1.516 2.63H3.72c-1.347 0-2.189-1.46-1.515-2.63L8.485 2.495ZM10 6a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 6Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>
                        </span>
                        Current Incident
                    </a>
                </li>
                <li>
                    <a class="oc-nav-link @(_path.StartsWith("/app/chat") ? "oc-nav-link--active" : "")"
                       href="/app/chat@_ts">
                        <span class="oc-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M15.98 1.804a1 1 0 0 0-1.96 0l-.24 1.192a1 1 0 0 1-.784.785l-1.192.238a1 1 0 0 0 0 1.962l1.192.238a1 1 0 0 1 .785.785l.238 1.192a1 1 0 0 0 1.962 0l.238-1.192a1 1 0 0 1 .785-.785l1.192-.238a1 1 0 0 0 0-1.962l-1.192-.238a1 1 0 0 1-.785-.785l-.238-1.192ZM6.949 5.684a1 1 0 0 0-1.898 0l-.683 2.051a1 1 0 0 1-.633.633l-2.051.683a1 1 0 0 0 0 1.898l2.051.684a1 1 0 0 1 .633.632l.683 2.051a1 1 0 0 0 1.898 0l.683-2.051a1 1 0 0 1 .633-.633l2.051-.683a1 1 0 0 0 0-1.898l-2.051-.683a1 1 0 0 1-.633-.633L6.95 5.684ZM13.949 13.684a1 1 0 0 0-1.898 0l-.184.551a1 1 0 0 1-.632.633l-.551.183a1 1 0 0 0 0 1.898l.551.183a1 1 0 0 1 .633.633l.183.551a1 1 0 0 0 1.898 0l.184-.551a1 1 0 0 1 .632-.633l.551-.183a1 1 0 0 0 0-1.898l-.551-.184a1 1 0 0 1-.633-.632l-.183-.551Z"/></svg>
                        </span>
                        Ask Copilot
                    </a>
                </li>
            </ul>
            <section class="oc-sidebar-context" aria-label="Current context">
                <span class="oc-sidebar-section-label">Active Context</span>
                <div class="oc-context-card">
                    <span class="oc-context-kicker">Focus</span>
                    <strong>@_contextLabel</strong>
                    <span class="oc-context-copy">Live reporting workspace for governed incident triage.</span>
                </div>
            </section>
            @if (!string.IsNullOrEmpty(_tid))
            {
                <div class="oc-sidebar-footer">
                    <span class="oc-sidebar-section-label">Tenant</span>
                    <span class="oc-tenant-badge">@_tid</span>
                </div>
            }
        </nav>
        <div class="oc-content-area">
            <main class="oc-main">
                @Body
            </main>
            <footer class="oc-footer">
                <small>🛡️ Ops Copilot Operator UI &mdash; read-only view</small>
            </footer>
        </div>
    </div>
</div>
