###############################################################################
# AM — Packs → Triage Integration (Slice 36)
#
# Pack enrichment adds three NEW nullable fields to the triage response:
#   packRunbooks[]            — runbook details from Mode-A packs
#   packEvidenceCollectors[]  — evidence-collector details from Mode-A packs
#   packErrors[]              — non-fatal errors (null when none)
#
# Requirements:
#   - Packs:RootPath must be configured with at least one valid pack on disk.
#   - Only packs with minimumMode="A" are surfaced (Mode A only).
#   - Runbook content is truncated at 2 000 characters.
###############################################################################

### AM1 — Triage with pack enrichment (happy path)
# Expected: 200 OK, packRunbooks[] and packEvidenceCollectors[] populated
#   for packs whose minimumMode="A" and that target the alerted resource type.
#   packErrors is null (no errors).
# @name triageWithPackEnrichment
POST {{baseUrl}}/agent/triage
Content-Type: application/json
x-tenant-id: {{tenantId}}

{
  "alertPayload": {
    "alertSource": "Azure Monitor",
