###############################################################################
# AQ.  Packs → SafeActions Proposals  (Dev Slice 44)
#
# Slice 44 enables packs to surface SafeAction recommendations during
# triage as proposals only — never auto-approved, never auto-executed.
# The new TriageResponse field `packSafeActionProposals` is an array
# of PackSafeActionProposalDto objects.
#
# Feature gates:
#   • Packs:DeploymentMode ≥ "B"  (gate 1 — mode check)
#   • Packs:SafeActionsEnabled = true  (gate 2 — feature flag)
#   • Per-action: action.RequiresMode ≤ deploymentMode (gate 3)
#
# With FileSystemPackLoader Rule 9 requiring RequiresMode="C" for all
# safeActions, proposals are only returned when DeploymentMode = "C".
#
# Scenario matrix:
#   AQ1 — ModeC triage → proposals populated (happy path)
#   AQ2 — ModeB triage → proposals empty (per-action filter)
#   AQ3 — ModeA triage → proposals empty (mode gate)
#   AQ4 — Feature disabled → proposals null/empty
#   AQ5 — No matching packs → proposals empty
#   AQ6 — ModeC triage → DTO shape verification
###############################################################################

### AQ1 — ModeC triage: SafeActions proposals populated (happy path)
# Expected: 200 OK.  Response contains packSafeActionProposals[] with at
#   least one item if the azure-vm pack has safeActions defined.  Each
#   proposal has: packName, packVersion, actionId, requiresMode ("C"),
#   displayName, actionType, parametersJson (may be null), and errorMessage
#   (null on success).  Proposals are informational only — no execution.
# NOTE: Server must be in Mode C (Packs:DeploymentMode = "C") with
#   Packs:SafeActionsEnabled = true.
# @name triageModeC_SafeActionProposals
POST {{baseUrl}}/agent/triage
Content-Type: application/json
x-tenant-id: {{tenantId}}

{
  "alertPayload": {
    "alertSource": "Azure Monitor",
    "fingerprint": "aq1-modec-proposals-01",
    "title": "High CPU on prod-vm-01 — SafeActions proposals verification",
    "severity": "High",
    "firedAtUtc": "2025-07-25T10:00:00Z",
    "signalType": "Metric",
    "resourceId": "/subscriptions/sub-abc/resourceGroups/prod-rg/providers/Microsoft.Compute/virtualMachines/prod-vm-01",
    "serviceName": "prod-vm-01",
