### AJ3 — Tenant isolation: same action, different tenants ⇒ different outcomes
# tenant-restricted-33 denies "kql_query", default tenant allows it.
# Expected: 400 Bad Request with reasonCode="governance_tool_denied"
# @name proposeAJ3Isolation
POST {{baseUrl}}/safe-actions/propose
Content-Type: application/json
x-tenant-id: tenant-restricted-33

{
  "correlationId": "{{$guid}}",
  "actionType": "kql_query",
  "proposedPayloadJson": "{\"query\":\"Heartbeat | take 1\"}",
  "rollbackPayloadJson": "{}",
  "dryRun": false
}

### AJ4 — Frozen reason code preserved through HTTP layer
# Repeats AJ1 scenario; explicitly asserts the JSON body shape:
#   { "reasonCode": "governance_tool_denied", "message": "...policyReason=..." }
# Expected: 400 Bad Request, body contains "governance_tool_denied" and "policyReason="
# @name proposeAJ4FrozenCode
POST {{baseUrl}}/safe-actions/propose
Content-Type: application/json
x-tenant-id: tenant-restricted-33

{
