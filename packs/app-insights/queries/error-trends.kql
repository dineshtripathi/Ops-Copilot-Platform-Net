// Error trends: count and rate of errors over time
// Binned into 5-minute intervals to show progression
requests
| where timestamp > ago(30m)
| extend IsError = iff(success == false, 1, 0)
| summarize 
    TotalRequests = count(),
    FailedCount = sum(IsError),
    ErrorRate = sum(IsError) * 100.0 / count()
    by bin(timestamp, 5m)
| order by timestamp desc
