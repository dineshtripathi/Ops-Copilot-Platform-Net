// Error trends: count and rate of errors over time
// Workspace schema: AppRequests
AppRequests
| where TimeGenerated > ago(2d)
| extend IsError = iff(Success == false, 1, 0)
| summarize
    TotalRequests = count(),
    FailedCount = sum(IsError),
    ErrorRate = iff(count() == 0, 0.0, sum(IsError) * 100.0 / count())
    by timestamp = bin(TimeGenerated, 5m)
| order by timestamp desc
