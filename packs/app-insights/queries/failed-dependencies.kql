// Failed external dependencies in the last 30 minutes
// Workspace schema: AppDependencies
AppDependencies
| where TimeGenerated > ago(2d) and Success == false
| summarize
    Count = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    ResultCodes = make_set(tostring(ResultCode), 10)
    by type = tostring(DependencyType), target = tostring(Target)
| order by Count desc
| take 25
