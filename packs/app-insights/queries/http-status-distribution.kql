// Distribution of HTTP status codes in the last 30 minutes
// Workspace schema: AppRequests
let Total = toscalar(AppRequests | where TimeGenerated > ago(2d) | count);
AppRequests
| where TimeGenerated > ago(2d)
| extend statusCode = toint(ResultCode)
| extend StatusFamily = case(
    statusCode >= 500, "5xx",
    statusCode >= 400, "4xx",
    statusCode >= 300, "3xx",
    statusCode >= 200, "2xx",
    "Other")
| summarize Count = count() by StatusFamily, resultCode = tostring(ResultCode)
| extend Percentage = iff(Total == 0, 0.0, Count * 100.0 / todouble(Total))
| order by Count desc
