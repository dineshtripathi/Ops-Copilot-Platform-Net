// Top exceptions in the last 5 days
// Workspace schema: AppExceptions
AppExceptions
| where TimeGenerated > ago(5d)
| summarize
    Count = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    SampleMessage = any(OuterMessage)
    by exceptionType = tostring(Type)
| order by Count desc
| take 20
