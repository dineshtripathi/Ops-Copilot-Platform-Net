// Timeout patterns: requests exceeding 30 seconds
// Indicates performance degradation or resource exhaustion
requests
| where timestamp > ago(30m) and duration > 30000
| summarize 
    Count = count(),
    AvgDuration = avg(duration),
    MaxDuration = max(duration),
    P95Duration = percentile(duration, 95)
    by url, resultCode
| order by Count desc
| take 20
